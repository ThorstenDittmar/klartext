# Python
__pycache__/
*.py[cod]
*.pyo
# No trailing slash: in worktrees the venv is often a symlink to a shared
# venv (e.g. api/.venv -> ~/klartext/api/.venv). A trailing-slash pattern
# matches directories only, not symlinks, letting the symlink show as untracked.
.venv
venv
.env
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage

# Node / Frontend
node_modules/
dist/
.cache/
frontend/.env.local
frontend/.env.*.local

# Supabase
supabase/.temp/

# MkDocs
site/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# External reference assets — local only (licensed material, large binaries; not committed)
# See assets-local/README.md for the file register and conventions.
assets-local/*
!assets-local/README.md

# Claude Code — compact monitor runtime data (machine-specific, not versioned)
.claude/compact-log.txt
.claude/compact-snapshots/
.claude/compact-log-lastcheck
.claude/compact-monitor-digest.txt
.claude/compact-monitor.log

# Claude Code — desktop-app session worktrees (checkout-in-checkout; never versioned)
.claude/worktrees/
