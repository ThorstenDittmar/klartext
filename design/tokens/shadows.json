{
  "$description": "Klartext shadow tokens — source of truth. Use sparingly — prefer flat, border-based separation.",
  "shadow": {
    "none": { "$value": "none", "$type": "shadow" },
    "xs":   { "$value": "0 1px 2px rgba(0,0,0,0.06)", "$type": "shadow", "$description": "Subtle hover state" },
    "sm":   { "$value": "0 1px 4px rgba(0,0,0,0.08)", "$type": "shadow", "$description": "Cards on scroll elevation" },
    "md":   { "$value": "0 2px 8px rgba(0,0,0,0.10)", "$type": "shadow", "$description": "Dropdowns, floating elements" },
    "lg":   { "$value": "0 4px 16px rgba(0,0,0,0.12)", "$type": "shadow", "$description": "Modals, overlays" }
  }
}
