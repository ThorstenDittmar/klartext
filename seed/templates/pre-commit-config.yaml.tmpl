# Pre-commit hooks (method-seed template). Ships the one fully-generic Way-of-Working hook:
#   - agent-trailer: the ADR-0014 `Agent: <slug>` commit-msg provenance trailer
# Install once after cloning: pre-commit install
#
# The agent-trailer runs the interpreter via the portable `bin/seed-python` shim (rendered from
# seed.toml's `interpreter`), so there is no hardcoded venv layout to edit.

default_install_hook_types: [pre-commit, commit-msg]

repos:
  # ---------------------------------------------------------------------------
  # SLOT — add the importer's stack-specific tools here. Their MECHANISM is generic but their
  # rules + file-filters are the consumer's own (Standards-Charter cut), so they do not ship active:
  #   - stack linters: ruff / mypy / tach / eslint / tsc / …
  #   - semgrep architectural linting (recommended): wire your own rules + types_or, e.g.
  #       - repo: local
  #         hooks:
  #           - id: semgrep
  #             name: semgrep (architectural rules)
  #             entry: semgrep
  #             language: system
  #             args: [scan, --config=<your-rules-dir>/, --error, --metrics=off]
  #             pass_filenames: false
  #             types_or: [<your-languages>]
  # ---------------------------------------------------------------------------

  # ---------------------------------------------------------------------------
  # Agent provenance: the ADR-0014 `Agent: <slug>` commit trailer (commit-msg stage)
  # ---------------------------------------------------------------------------
  - repo: local
    hooks:
      - id: agent-trailer
        name: agent provenance trailer (ADR-0014)
        entry: bin/seed-python scripts/agent_trailer.py
        language: system
        stages: [commit-msg]   # receives the commit-msg file; adds/validates the Agent trailer
