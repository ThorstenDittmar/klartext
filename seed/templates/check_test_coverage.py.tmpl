#!/usr/bin/env python3
"""Structural test-coverage check for {{project_name}} — Coverage-Invariant 1 (source -> test).

Every source file under the configured source dirs must have a matching test file. This is the one
coverage invariant the method seed ships as live, config-driven code (the seed/QA verdict); the
router-health and supabase-integration-marker checks are documented patterns, not live checks here —
a consumer on a foreign stack would otherwise inherit dead code + dead config.

Config is read from seed.toml at RUNTIME (the single source, like scripts/classify_gate.py):
  source_dirs          — the source layer dirs under backend_dir (e.g. models, services)
  excluded_files       — filenames with no domain logic to skip (e.g. __init__.py)
  test_file_overrides  — list of "source.py=test_file.py" strings for non-default test names
  backend_dir          — the product stack root, repo-relative (e.g. api)
  tests_dir            — the tests dir, repo-relative (e.g. api/tests)
"""

from __future__ import annotations

import sys
import tomllib
from pathlib import Path
from typing import NamedTuple

_SEED_TOML = Path(__file__).resolve().parents[1] / "seed" / "seed.toml"


class CoverageConfig(NamedTuple):
    """The runtime coverage config sourced from seed.toml (Coverage-Invariant 1)."""

    source_dirs: list[str]
    excluded_files: set[str]
    test_file_overrides: dict[str, str]
    backend_dir: str
    tests_dir: str


def load_config(seed_path: Path = _SEED_TOML) -> CoverageConfig:
    """Reads the coverage config from seed.toml. Fail-loud (KeyError) on a missing key."""
    with seed_path.open("rb") as handle:
        config = tomllib.load(handle)
    overrides: dict[str, str] = {}
    for item in config["test_file_overrides"]:
        key, sep, value = str(item).partition("=")
        if not sep:
            raise ValueError(
                f"test_file_overrides entry {item!r} is malformed — "
                "expected 'source.py=test_file.py'"
            )
        overrides[key] = value
    return CoverageConfig(
        source_dirs=[str(x) for x in config["source_dirs"]],
        excluded_files={str(x) for x in config["excluded_files"]},
        test_file_overrides=overrides,
        backend_dir=str(config["backend_dir"]),
        tests_dir=str(config["tests_dir"]),
    )


def check_test_files_exist(root: Path | None = None) -> list[str]:
    """Returns source files (under the configured source dirs) that have no matching test file.

    Excluded files are skipped. Files in test_file_overrides match by explicit name; all others use
    prefix matching: any test_<stem>*.py file is accepted.
    """
    if root is None:
        root = Path(__file__).resolve().parents[1]
    cfg = load_config()
    backend_dir = root / cfg.backend_dir
    tests_dir = root / cfg.tests_dir
    missing: list[str] = []
    for source_dir in cfg.source_dirs:
        dir_path = backend_dir / source_dir
        if not dir_path.exists():
            continue
        for source_file in sorted(dir_path.glob("*.py")):
            if source_file.name in cfg.excluded_files:
                continue
            if source_file.name in cfg.test_file_overrides:
                expected = cfg.test_file_overrides[source_file.name]
                if not (tests_dir / expected).exists():
                    missing.append(
                        f"  {source_file.relative_to(root)}  ->  {cfg.tests_dir}/{expected}"
                    )
                continue
            if not list(tests_dir.glob(f"test_{source_file.stem}*.py")):
                missing.append(
                    f"  {source_file.relative_to(root)}  ->  {cfg.tests_dir}/test_{source_file.name}"
                )
    return missing


def main() -> None:
    """Runs Coverage-Invariant 1 and exits with code 1 if any source file lacks a test."""
    missing = check_test_files_exist()
    if missing:
        print("ERROR: test coverage check failed:\n")
        print("Source files without test files:")
        for item in missing:
            print(item)
        sys.exit(1)
    print("OK: all structural test coverage checks passed.")


if __name__ == "__main__":
    main()
